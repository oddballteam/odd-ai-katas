---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const katas = await getCollection('katas');
  return katas
    .filter(k => !k.data.stub && !k.data.description?.startsWith('DEPRECATED'))
    .map((kata) => ({
      params: { slug: kata.id },
      props: { kata },
    }));
}

const { kata } = Astro.props;
const { Content } = await render(kata);
---

<Base title={`${kata.data.feeling} — AI Katas`}>
  <main class="kata-detail" style="display: block; position: relative; z-index: 1;">
    <a href={`${import.meta.env.BASE_URL}`} class="kata-back">&#8592; Back to all katas</a>

    <div class="feeling-title">"{kata.data.feeling}"</div>

    <div class="kata-body">
      <Content />
    </div>
  </main>

  <!-- Dot grid animation for standalone pages -->
  <script is:inline>
  (function() {
    const canvas = document.getElementById('dotCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const spacing = 40, dotRadius = 1.2;
    let offsetX = 0, offsetY = 0;
    const color = '#D97757';

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    function hexToRgb(hex) {
      return `${parseInt(hex.slice(1,3),16)},${parseInt(hex.slice(3,5),16)},${parseInt(hex.slice(5,7),16)}`;
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const rgb = hexToRgb(color);
      const startX = (offsetX % spacing) - spacing;
      const startY = (offsetY % spacing) - spacing;
      for (let x = startX; x < canvas.width + spacing; x += spacing) {
        for (let y = startY; y < canvas.height + spacing; y += spacing) {
          ctx.beginPath();
          ctx.arc(x, y, dotRadius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${rgb}, 0.35)`;
          ctx.fill();
        }
      }
      offsetX += 0.15;
      offsetY += 0.08;
      requestAnimationFrame(draw);
    }
    draw();
  })();
  </script>
</Base>
