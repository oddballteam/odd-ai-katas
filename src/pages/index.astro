---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { tools, toolGroups, toolThemes } from '../data/tool-content';
import { kataSequence } from '../data/kata-sequence';

// Priority order for displaying tool tags (lower index = shown first)
const toolPriority = ['claude-code', 'cowork', 'vscode', 'cursor', 'gemini-cli', 'antigravity', 'codex'];
function sortTools(toolIds: string[]) {
  return [...toolIds].sort((a, b) => {
    const ai = toolPriority.indexOf(a);
    const bi = toolPriority.indexOf(b);
    return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
  });
}

// Fetch all katas and render their MDX content at build time
const allKatas = await getCollection('katas');

// Filter out deprecated files and sort by kata-sequence.ts (unlisted katas go to the end alphabetically)
const katas = allKatas
  .filter(k => !k.data.description?.startsWith('DEPRECATED'))
  .sort((a, b) => {
    const ai = kataSequence.indexOf(a.id);
    const bi = kataSequence.indexOf(b.id);
    return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
  });

// Build a JSON-serializable kata manifest for client JS
// For drafts, extract version from filename (e.g. glossary-v4 -> v4) and append to title
function draftFeeling(kata: { id: string; data: { feeling: string; status?: string } }) {
  if (kata.data.status !== 'draft') return kata.data.feeling;
  const match = kata.id.match(/-v(\d+)$/);
  return match ? `${kata.data.feeling} (v${match[1]})` : kata.data.feeling;
}
let displayOrder = 0;
const kataManifest = katas.map((kata, i) => {
  const isPrimary = !kata.data.variant && kata.data.status !== 'draft';
  if (isPrimary) displayOrder++;
  return {
    id: kata.id,
    feeling: draftFeeling(kata),
    variant: kata.data.variant || '',
    variantOf: kata.data.variantOf || '',
    takeaway: kata.data.takeaway || '',
    description: kata.data.description,
    related: kata.data.related || [],
    stub: kata.data.stub || false,
    status: kata.data.status || '',
    tools: sortTools(kata.data.tools || []),
    tags: kata.data.tags || [],
    lastUpdated: kata.data.lastUpdated || '',
    order: isPrimary ? displayOrder - 1 : -1,
  };
});

// Collect all unique tags across katas
const allTags = [...new Set(katas.flatMap(k => k.data.tags || []))].sort();

// Build a flat tool lookup: id -> { name, company, accent }
const toolLookup = toolGroups.flatMap(g =>
  g.tools.map(t => ({ id: t.id, name: t.name, company: g.company, accent: g.accent, svg: t.svg }))
);

---

<Base title="AI Katas">
  <header class="hero">
    <h1><a href="#" onclick="window.__hideKata && window.__hideKata(); return false;" style="color: inherit; text-decoration: none;"><span>AI</span> Katas</a></h1>
    <div class="hero-progress" id="hero-progress">0/{katas.filter(k => !k.data.variant && k.data.status !== 'draft').length} completed</div>
    <div class="hero-line"></div>
  </header>


  <!-- Grid view -->
  <main class="main" id="main-grid">
    <div class="section-header">
      <div class="section-label">Level up</div>
      <div class="section-count" id="kata-count">{katas.length} katas</div>
      <div class="section-controls">
        <button class="caveman-toggle" id="caveman-toggle">&#x1f9cc; Caveman mode</button>
        <label class="draft-toggle">
          <input type="checkbox" id="show-drafts" />
          <span>Show drafts</span>
        </label>
        <button class="reset-progress" id="reset-progress">Reset progress</button>
      </div>
    </div>
    <div class="kata-grid">
      {(() => { let displayNum = 0; return katas.map((kata, i) => {
        const isPrimary = !kata.data.variant && kata.data.status !== 'draft';
        if (isPrimary) displayNum++;
        const num = isPrimary ? displayNum : null;
        return (
        <a
          class={`kata-card${kata.data.stub ? ' stub' : ''}${kata.data.status === 'draft' ? ' draft' : ''}`}
          href="#"
          data-kata-id={kata.id}
          data-has-content={!kata.data.stub ? 'true' : 'false'}
          data-tools={(kata.data.tools || []).join(',')}
          data-tags={(kata.data.tags || []).join(',')}
          data-status={kata.data.status || 'done'}
          data-variant={kata.data.variant || ''}
          data-variant-of={kata.data.variantOf || ''}
        >
          <div class="card-content">
            <span class="kata-check" data-check-id={kata.id}></span>
            <span class="number">{num ? String(num).padStart(2, '0') : ''}</span>
            <span class="feeling">{draftFeeling(kata)}</span>
            {kata.data.takeaway && <span class="takeaway">{kata.data.takeaway}</span>}
          </div>
          {kata.data.status === 'draft' && <span class="draft-slug">{kata.id}</span>}
          <div class="card-tags">
            {sortTools(kata.data.tools || []).map(toolId => {
              const t = toolLookup.find(tl => tl.id === toolId);
              return t ? (
                <span class="tool-tag" data-tool-tag={toolId} style={`--tag-color: ${toolThemes[toolId]?.accent || '#888'}`}>
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={t.svg} />
                </span>
              ) : null;
            })}
          </div>
        </a>
      ); }); })()}
    </div>
  </main>

  <!-- Kata detail view (hidden by default, populated by JS) -->
  <div class="kata-detail" id="kata-detail"></div>

  <!--
    Pre-rendered kata bodies (hidden, used as content source for JS).
    Note: This content is author-controlled MDX rendered at build time,
    not user-supplied input. The innerHTML usage in the client script
    only reads from these pre-rendered elements.
  -->
  <div id="kata-bodies" style="display:none;">
    {katas.filter(k => !k.data.stub).map(async (kata) => {
      const { Content } = await render(kata);
      return (
        <div data-kata-body={kata.id}>
          <Content />
        </div>
      );
    })}
  </div>

  <!--
    Embed data for client JS.
    All data here is author-controlled (from tool-content.ts and MDX files),
    serialized at build time. No user input flows into these values.
  -->
  <script is:inline define:vars={{ kataManifest, toolThemes, toolLookup, toolPriority, basePath: import.meta.env.BASE_URL }}>
    window.__KATA_DATA__ = {
      katas: kataManifest,
      toolThemes: toolThemes,
      basePath: basePath,
      toolLookup: toolLookup,
      toolPriority: toolPriority,
    };
  </script>

  <!--
    Client-side SPA logic.
    All dynamic content is sourced from build-time data (MDX renders + tool-content.ts).
    No user-supplied content is rendered as HTML.
  -->
  <script is:inline>
  (function() {
    var data = window.__KATA_DATA__;
    var katas = data.katas;
    var kataMap = {};
    katas.forEach(function(k) { kataMap[k.id] = k; });

    var mainEl = document.getElementById('main-grid');
    var detailEl = document.getElementById('kata-detail');
    var bodiesEl = document.getElementById('kata-bodies');
    var countEl = document.getElementById('kata-count');

    // Track active filter and active tool (for detail view tool steps)
    var activeFilter = 'all';
    var activeTagFilter = 'all';
    var showDrafts = false;
    var cavemanMode = false;
    var activeTool = null;

    // ===== Draft toggle =====
    var draftToggle = document.getElementById('show-drafts');
    draftToggle.addEventListener('change', function() {
      showDrafts = draftToggle.checked;
      filterCards();
    });

    // ===== Caveman toggle =====
    // Build a map of normal kata id -> caveman kata data for text swapping
    var cavemanMap = {};
    var normalMap = {};
    katas.forEach(function(k) {
      if (k.variant === 'caveman' && k.variantOf) {
        cavemanMap[k.variantOf] = k;
      }
      if (!k.variant) {
        normalMap[k.id] = k;
      }
    });

    var cavemanToggle = document.getElementById('caveman-toggle');
    cavemanToggle.addEventListener('click', function() {
      cavemanMode = !cavemanMode;
      cavemanToggle.classList.toggle('active', cavemanMode);
      document.body.classList.toggle('caveman', cavemanMode);
      // Swap card text
      document.querySelectorAll('.kata-card').forEach(function(card) {
        var id = card.dataset.kataId;
        var caveman = cavemanMap[id];
        var normal = normalMap[id];
        if (caveman && normal) {
          var feelingEl = card.querySelector('.feeling');
          var source = cavemanMode ? caveman : normal;
          if (feelingEl) feelingEl.textContent = source.feeling;
        }
      });
      filterCards();
    });

    // ===== Completion tracking =====
    var STORAGE_KEY = 'ai-katas-completed';
    function getCompleted() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
    }
    function setCompleted(list) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    }
    function isCompleted(id) {
      return getCompleted().indexOf(id) !== -1;
    }
    function toggleCompleted(id) {
      var list = getCompleted();
      var idx = list.indexOf(id);
      if (idx === -1) { list.push(id); } else { list.splice(idx, 1); }
      setCompleted(list);
      updateCompletionUI();
    }
    function updateCompletionUI() {
      var completed = getCompleted();
      // Update progress counter
      var progressEl = document.getElementById('hero-progress');
      var primaryCount = katas.filter(function(k) { return !k.variant && k.status !== 'draft'; }).length;
      var primaryCompleted = completed.filter(function(id) {
        var k = kataMap[id];
        return k && !k.variant && k.status !== 'draft';
      }).length;
      if (progressEl) progressEl.textContent = primaryCompleted + '/' + primaryCount + ' completed';
      // Update card checkmarks
      document.querySelectorAll('.kata-check').forEach(function(el) {
        var done = completed.indexOf(el.dataset.checkId) !== -1;
        el.classList.toggle('done', done);
        el.closest('.kata-card').classList.toggle('completed', done);
      });
    }
    // Reset progress button
    document.getElementById('reset-progress').addEventListener('click', function() {
      if (confirm('Reset all progress?')) {
        localStorage.removeItem(STORAGE_KEY);
        updateCompletionUI();
      }
    });

    // Init on load
    updateCompletionUI();
    filterCards();

    // ===== Filter pills =====
    var pills = document.querySelectorAll('.filter-pill');
    pills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        pills.forEach(function(p) { p.classList.remove('active'); });
        pill.classList.add('active');
        activeFilter = pill.dataset.filter;

        // Apply theme when a specific tool is selected
        if (activeFilter !== 'all') {
          activeTool = activeFilter;
          applyToolTheme(activeFilter);
        } else {
          activeTool = null;
          applyToolTheme('cowork'); // default
        }

        filterCards();
      });
    });

    // ===== Tag filter pills =====
    var tagPills = document.querySelectorAll('.tag-pill');
    tagPills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        tagPills.forEach(function(p) { p.classList.remove('active'); });
        pill.classList.add('active');
        activeTagFilter = pill.dataset.tagFilter;
        filterCards();
      });
    });

    function filterCards() {
      var cards = document.querySelectorAll('.kata-card');
      var visible = 0;
      cards.forEach(function(card) {
        var cardTools = (card.dataset.tools || '').split(',');
        var cardTags = (card.dataset.tags || '').split(',');
        var isDraft = card.dataset.status === 'draft';
        var isCaveman = card.dataset.variant === 'caveman';
        var hasCavemanVariant = card.dataset.variantOf === '' && !isCaveman &&
          document.querySelector('.kata-card[data-variant-of="' + card.dataset.kataId + '"]');
        var toolMatch = activeFilter === 'all' || cardTools.indexOf(activeFilter) !== -1;
        var tagMatch = activeTagFilter === 'all' || cardTags.indexOf(activeTagFilter) !== -1;
        var draftMatch = !isDraft || showDrafts;
        var cavemanMatch = cavemanMode ? !hasCavemanVariant : !isCaveman;
        var show = toolMatch && tagMatch && draftMatch && cavemanMatch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      countEl.textContent = visible + ' kata' + (visible !== 1 ? 's' : '');
    }

    // ===== Card click handlers =====
    document.querySelectorAll('.kata-card').forEach(function(card) {
      card.addEventListener('click', function(e) {
        e.preventDefault();
        if (card.dataset.hasContent === 'true') {
          showKata(card.dataset.kataId);
        }
      });
    });

    function showKata(id) {
      // In caveman mode, redirect to caveman variant if one exists
      var displayId = id;
      if (cavemanMode && cavemanMap[id]) {
        displayId = cavemanMap[id].id;
      }
      var kata = kataMap[displayId] || kataMap[id];
      if (!kata) return;
      var orderSource = kataMap[id] || kata;
      var num = orderSource.order >= 0 ? String(orderSource.order + 1).padStart(2, '0') : '';

      // Get pre-rendered body (build-time MDX content)
      var bodyEl = bodiesEl.querySelector('[data-kata-body="' + displayId + '"]');
      var bodyHTML = bodyEl ? bodyEl.innerHTML : '';

      // Tool tags for this kata
      var toolTagsHTML = '';
      if (kata.tools && kata.tools.length) {
        var tags = kata.tools.map(function(toolId) {
          var toolInfo = data.toolLookup.find(function(t) { return t.id === toolId; });
          if (!toolInfo) return '';
          var theme = data.toolThemes[toolId];
          var color = theme ? theme.accent : '#888';
          return '<span class="detail-tool-tag" style="--tag-color: ' + color + '">' +
            '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">' + toolInfo.svg + '</svg>' +
            toolInfo.name + '</span>';
        }).join('');
        toolTagsHTML = '<div class="detail-tool-tags">' + tags + '</div>';
      }

      // Related katas
      var relatedHTML = '';
      if (kata.related && kata.related.length) {
        var bubbles = kata.related.map(function(rid) {
          var r = kataMap[rid];
          if (!r) return '';
          var rnum = String(r.order + 1).padStart(2, '0');
          var clickable = !r.stub ? ' onclick="window.__showKata(\'' + rid + '\')"' : '';
          var dim = r.stub ? ' style="opacity:0.45; cursor:default;"' : '';
          return '<a class="kata-bubble"' + clickable + dim + '><span class="bubble-num">' + rnum + '</span> "' + r.feeling + '"</a>';
        }).join('');
        relatedHTML =
          '<div class="related-katas">' +
            '<div class="related-katas-label">Related katas</div>' +
            '<div class="related-bubbles">' + bubbles + '</div>' +
          '</div>';
      }

      // All content here is from build-time sources:
      // - kata manifest (from MDX frontmatter)
      // - bodyHTML (pre-rendered MDX)
      // - relatedHTML (built from kata manifest ids/feelings)
      // All content below is author-controlled static data from build-time sources
      // (MDX frontmatter, pre-rendered MDX bodies, tool-content.ts). No user input.
      var alreadyCompleted = isCompleted(id);
      var completedClass = alreadyCompleted ? ' done' : '';
      var completedText = 'Done, back to katas';
      detailEl.innerHTML =
        '<button class="kata-back" onclick="window.__hideKata()"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2L4 8l6 6"/></svg> Back to all katas</button>' +
        '<div class="kata-number">KATA ' + num + '</div>' +
        '<div class="feeling-title">' + kata.feeling + (kata.status === 'draft' ? ' <span class="draft-badge">DRAFT</span>' : '') + '</div>' +
        '<div class="kata-description">' + kata.description + '</div>' +
        (kata.lastUpdated ? '<div class="kata-last-updated">Last updated ' + kata.lastUpdated + '</div>' : '') +
        toolTagsHTML +
        '<div class="kata-body">' + bodyHTML + '</div>' +
        (alreadyCompleted ? '' : '<button class="kata-complete-btn" id="kata-complete-btn" data-kata-id="' + id + '">' + completedText + '</button>') +
        relatedHTML;

      // Wire up completion button
      var completeBtn = document.getElementById('kata-complete-btn');
      if (completeBtn) {
        completeBtn.addEventListener('click', function() {
          toggleCompleted(id);
          if (isCompleted(id)) {
            setTimeout(function() { hideKata(); }, 800);
          }
        });
      }

      // Style prompt blocks and add copy buttons
      detailEl.querySelectorAll('pre[data-language="plaintext"]').forEach(function(pre) {
        pre.classList.add('prompt-block');
        var btn = document.createElement('button');
        btn.className = 'prompt-copy';
        btn.textContent = 'Copy';
        btn.addEventListener('click', function() {
          var text = pre.querySelector('code').textContent;
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'Copied';
            setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
          });
        });
        pre.appendChild(btn);
      });

      // Add copy button to tables
      detailEl.querySelectorAll('table').forEach(function(table) {
        var wrapper = document.createElement('div');
        wrapper.className = 'table-copy-wrapper';
        table.parentNode.insertBefore(wrapper, table);
        wrapper.appendChild(table);
        var btn = document.createElement('button');
        btn.className = 'table-copy';
        btn.textContent = 'Copy';
        btn.addEventListener('click', function() {
          var rows = table.querySelectorAll('tbody tr');
          var text = Array.from(rows).map(function(row) {
            var cells = row.querySelectorAll('td');
            return cells[0].textContent.trim() + ': ' + cells[1].textContent.trim();
          }).join('\n');
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'Copied';
            setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
          });
        });
        wrapper.appendChild(btn);
      });

      mainEl.classList.add('hidden');
      detailEl.classList.add('visible');
      document.querySelector('.hero').style.display = 'none';
      document.querySelector('.oddball-banner').style.display = 'none';
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Update URL without reload
      history.pushState({ kata: id }, '', '#' + id);
    }

    function hideKata() {
      detailEl.classList.remove('visible');
      mainEl.classList.remove('hidden');
      document.querySelector('.hero').style.display = '';
      document.querySelector('.oddball-banner').style.display = '';
      detailEl.textContent = '';
      history.pushState({}, '', window.location.pathname);
    }

    // Expose for inline onclick handlers
    window.__showKata = showKata;
    window.__hideKata = hideKata;

    // Handle browser back button
    window.addEventListener('popstate', function(e) {
      if (e.state && e.state.kata) {
        showKata(e.state.kata);
      } else {
        hideKata();
      }
    });

    // Handle direct link to #kata-id
    if (window.location.hash) {
      var hashId = window.location.hash.slice(1);
      if (kataMap[hashId] && !kataMap[hashId].stub) {
        showKata(hashId);
      }
    }

    // ===== Tool theme =====
    var toolThemes = data.toolThemes;

    function applyToolTheme(toolId) {
      var theme = toolThemes[toolId];
      if (!theme) return;
      var r = document.documentElement;
      r.style.setProperty('--accent', theme.accent);
      r.style.setProperty('--cyan', theme.cyan);
      r.style.setProperty('--accent-glow', theme.glow);
      if (window._setDotColor) window._setDotColor(theme.accent);
    }

    // Apply initial theme
    applyToolTheme('cowork');

    // ===== Collapsible sections =====
    document.addEventListener('click', function(e) {
      var header = e.target.closest('.collapsible-header');
      if (header) {
        header.parentElement.classList.toggle('open');
      }
    });

    // ===== Animated dot grid canvas =====
    (function() {
      var canvas = document.getElementById('dotCanvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var spacing = 40;
      var dotRadius = 1.2;
      var offsetX = 0, offsetY = 0;
      var currentColor = '#00A187';

      window._setDotColor = function(hex) { currentColor = hex; };

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      window.addEventListener('resize', resize);
      resize();

      function hexToRgb(hex) {
        var r = parseInt(hex.slice(1,3),16);
        var g = parseInt(hex.slice(3,5),16);
        var b = parseInt(hex.slice(5,7),16);
        return r + ',' + g + ',' + b;
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        var rgb = hexToRgb(currentColor);
        var startX = (offsetX % spacing) - spacing;
        var startY = (offsetY % spacing) - spacing;
        for (var x = startX; x < canvas.width + spacing; x += spacing) {
          for (var y = startY; y < canvas.height + spacing; y += spacing) {
            ctx.beginPath();
            ctx.arc(x, y, dotRadius, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + rgb + ', 0.35)';
            ctx.fill();
          }
        }
        offsetX += 0.15;
        offsetY += 0.08;
        requestAnimationFrame(draw);
      }

      draw();
    })();
  })();
  </script>
</Base>
