---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { tools, toolGroups, toolThemes } from '../data/tool-content';

// Fetch all katas and render their MDX content at build time
const allKatas = await getCollection('katas');

// Filter out deprecated files and sort by order
const katas = allKatas
  .filter(k => !k.data.description?.startsWith('DEPRECATED'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Build a JSON-serializable kata manifest for client JS
const kataManifest = katas.map((kata, i) => ({
  id: kata.id,
  feeling: kata.data.feeling,
  description: kata.data.description,
  related: kata.data.related || [],
  stub: kata.data.stub || false,
  order: i,
}));

// Build toolSteps from kata frontmatter (co-located with each kata)
const toolSteps: Record<string, Record<string, Record<string, string>>> = {};
for (const kata of katas) {
  if (kata.data.toolSteps) {
    toolSteps[kata.id] = kata.data.toolSteps;
  }
}

// Serialize tool groups for client JS
const toolGroupsData = toolGroups.map(g => ({
  company: g.company,
  accent: g.accent,
  tools: g.tools.map(t => ({ id: t.id, name: t.name })),
}));
---

<Base title="AI Katas">
  <header class="hero">
    <h1><span>AI</span> Katas</h1>
    <div class="hero-line"></div>
  </header>

  <!-- Tool picker grouped by company -->
  <div class="tool-bar">
    <span class="tool-bar-label">Show for:</span>
    {toolGroups.map((group, gi) => (
      <div class="tool-group">
        <span class="tool-group-label">{group.company}</span>
        <div class="tool-group-buttons">
          {group.tools.map((tool, ti) => (
            <div class={`tool-btn${gi === 0 && ti === 0 ? ' active' : ''}`} data-tool={tool.id}>
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={tool.svg} />
              <span class="tool-name">{tool.name}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Grid view -->
  <main class="main" id="main-grid">
    <div class="section-header">
      <div class="section-label">What brings you to the dojo?</div>
      <div class="section-count">{katas.length} katas</div>
    </div>
    <div class="kata-grid">
      {katas.map((kata, i) => (
        <a
          class={`kata-card${kata.data.stub ? ' stub' : ''}`}
          href="#"
          data-kata-id={kata.id}
          data-has-content={!kata.data.stub ? 'true' : 'false'}
        >
          <span class="number">{String(i + 1).padStart(2, '0')}</span>
          <span class="feeling">"{kata.data.feeling}"</span>
        </a>
      ))}
    </div>
  </main>

  <!-- Kata detail view (hidden by default, populated by JS) -->
  <div class="kata-detail" id="kata-detail"></div>

  <!--
    Pre-rendered kata bodies (hidden, used as content source for JS).
    Note: This content is author-controlled MDX rendered at build time,
    not user-supplied input. The innerHTML usage in the client script
    only reads from these pre-rendered elements.
  -->
  <div id="kata-bodies" style="display:none;">
    {katas.filter(k => !k.data.stub).map(async (kata) => {
      const { Content } = await render(kata);
      return (
        <div data-kata-body={kata.id}>
          <Content />
        </div>
      );
    })}
  </div>

  <!--
    Embed data for client JS.
    All data here is author-controlled (from tool-content.ts and MDX files),
    serialized at build time. No user input flows into these values.
  -->
  <script is:inline define:vars={{ kataManifest, toolThemes, toolSteps, toolGroupsData }}>
    window.__KATA_DATA__ = {
      katas: kataManifest,
      toolThemes: toolThemes,
      toolSteps: toolSteps,
      toolGroups: toolGroupsData,
    };
  </script>

  <!--
    Client-side SPA logic.
    All dynamic content is sourced from build-time data (MDX renders + tool-content.ts).
    No user-supplied content is rendered as HTML.
  -->
  <script is:inline>
  (function() {
    var data = window.__KATA_DATA__;
    var katas = data.katas;
    var kataMap = {};
    katas.forEach(function(k) { kataMap[k.id] = k; });

    var mainEl = document.getElementById('main-grid');
    var detailEl = document.getElementById('kata-detail');
    var bodiesEl = document.getElementById('kata-bodies');

    // Track selected tool
    var activeTool = 'cowork';

    // ===== Card click handlers =====
    document.querySelectorAll('.kata-card').forEach(function(card) {
      card.addEventListener('click', function(e) {
        e.preventDefault();
        if (card.dataset.hasContent === 'true') {
          showKata(card.dataset.kataId);
        }
      });
    });

    function populateToolSteps(kataId) {
      var steps = data.toolSteps[kataId];
      if (!steps) return;

      document.querySelectorAll('.tool-step[data-step]').forEach(function(el) {
        var stepId = el.dataset.step;
        var stepData = steps[stepId];
        if (!stepData) return;

        // Build DOM with all tool variants, only active one visible.
        // Content is from build-time tool-content.ts (author-controlled).
        var container = document.createElement('div');
        container.className = 'tool-step-container';

        Object.keys(stepData).forEach(function(toolId) {
          var panel = document.createElement('div');
          panel.className = 'tool-step-panel' + (toolId === activeTool ? ' active' : '');
          panel.dataset.toolStep = toolId;
          // toolSteps content is author-controlled static data from tool-content.ts,
          // embedded at build time. No user input flows into this.
          panel.innerHTML = stepData[toolId];
          container.appendChild(panel);
        });

        el.textContent = '';
        el.appendChild(container);
      });
    }

    function showKata(id) {
      var kata = kataMap[id];
      if (!kata) return;
      var num = String(kata.order + 1).padStart(2, '0');

      // Get pre-rendered body (build-time MDX content)
      var bodyEl = bodiesEl.querySelector('[data-kata-body="' + id + '"]');
      var bodyHTML = bodyEl ? bodyEl.innerHTML : '';

      // Related katas
      var relatedHTML = '';
      if (kata.related && kata.related.length) {
        var bubbles = kata.related.map(function(rid) {
          var r = kataMap[rid];
          if (!r) return '';
          var rnum = String(r.order + 1).padStart(2, '0');
          var clickable = !r.stub ? ' onclick="window.__showKata(\'' + rid + '\')"' : '';
          var dim = r.stub ? ' style="opacity:0.45; cursor:default;"' : '';
          return '<a class="kata-bubble"' + clickable + dim + '><span class="bubble-num">' + rnum + '</span> "' + r.feeling + '"</a>';
        }).join('');
        relatedHTML =
          '<div class="related-katas">' +
            '<div class="related-katas-label">Related katas</div>' +
            '<div class="related-bubbles">' + bubbles + '</div>' +
          '</div>';
      }

      // All content here is from build-time sources:
      // - kata manifest (from MDX frontmatter)
      // - bodyHTML (pre-rendered MDX)
      // - relatedHTML (built from kata manifest ids/feelings)
      detailEl.innerHTML =
        '<button class="kata-back" onclick="window.__hideKata()">&#8592; Back to all katas</button>' +
        '<div class="kata-number">KATA ' + num + '</div>' +
        '<div class="feeling-title">"' + kata.feeling + '"</div>' +
        '<div class="kata-body">' + bodyHTML + '</div>' +
        relatedHTML;

      // Populate tool-step placeholders with active tool content
      populateToolSteps(id);

      mainEl.classList.add('hidden');
      detailEl.classList.add('visible');
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Update URL without reload
      history.pushState({ kata: id }, '', '#' + id);
    }

    function hideKata() {
      detailEl.classList.remove('visible');
      mainEl.classList.remove('hidden');
      detailEl.textContent = '';
      history.pushState({}, '', window.location.pathname);
    }

    // Expose for inline onclick handlers
    window.__showKata = showKata;
    window.__hideKata = hideKata;

    // Handle browser back button
    window.addEventListener('popstate', function(e) {
      if (e.state && e.state.kata) {
        showKata(e.state.kata);
      } else {
        hideKata();
      }
    });

    // Handle direct link to #kata-id
    if (window.location.hash) {
      var hashId = window.location.hash.slice(1);
      if (kataMap[hashId] && !kataMap[hashId].stub) {
        showKata(hashId);
      }
    }

    // ===== Tool picker =====
    var toolThemes = data.toolThemes;

    function applyToolTheme(toolId) {
      var theme = toolThemes[toolId];
      if (!theme) return;
      var r = document.documentElement;
      r.style.setProperty('--accent', theme.accent);
      r.style.setProperty('--cyan', theme.cyan);
      r.style.setProperty('--accent-glow', theme.glow);
      if (window._setDotColor) window._setDotColor(theme.accent);
    }

    function switchToolPanels(toolId) {
      document.querySelectorAll('.tool-step-panel').forEach(function(p) {
        if (p.dataset.toolStep === toolId) {
          p.classList.add('active');
        } else {
          p.classList.remove('active');
        }
      });
    }

    document.querySelectorAll('.tool-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tool-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        activeTool = btn.dataset.tool;
        applyToolTheme(activeTool);
        switchToolPanels(activeTool);
      });
    });

    // Apply initial theme
    applyToolTheme('cowork');

    // ===== Collapsible sections =====
    document.addEventListener('click', function(e) {
      var header = e.target.closest('.collapsible-header');
      if (header) {
        header.parentElement.classList.toggle('open');
      }
    });

    // ===== Animated dot grid canvas =====
    (function() {
      var canvas = document.getElementById('dotCanvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var spacing = 40;
      var dotRadius = 1.2;
      var offsetX = 0, offsetY = 0;
      var currentColor = toolThemes['cowork'] ? toolThemes['cowork'].accent : '#D97757';

      window._setDotColor = function(hex) { currentColor = hex; };

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      window.addEventListener('resize', resize);
      resize();

      function hexToRgb(hex) {
        var r = parseInt(hex.slice(1,3),16);
        var g = parseInt(hex.slice(3,5),16);
        var b = parseInt(hex.slice(5,7),16);
        return r + ',' + g + ',' + b;
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        var rgb = hexToRgb(currentColor);
        var startX = (offsetX % spacing) - spacing;
        var startY = (offsetY % spacing) - spacing;
        for (var x = startX; x < canvas.width + spacing; x += spacing) {
          for (var y = startY; y < canvas.height + spacing; y += spacing) {
            ctx.beginPath();
            ctx.arc(x, y, dotRadius, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(' + rgb + ', 0.35)';
            ctx.fill();
          }
        }
        offsetX += 0.15;
        offsetY += 0.08;
        requestAnimationFrame(draw);
      }

      draw();
    })();
  })();
  </script>
</Base>
