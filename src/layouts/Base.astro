---
interface Props {
  title?: string;
  minimal?: boolean;
}
const { title = 'AI Katas', minimal = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+JP:wght@700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="dot-grid"><canvas id="dotCanvas"></canvas></div>

    {!minimal && (
      <div class="oddball-banner">
        <img src="/odd-ai-katas/images/oddball-logo.webp" alt="Oddball logo" class="oddball-logo" />
      </div>
    )}

    <slot />

    {!minimal && <footer class="footer">AI Katas</footer>}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
