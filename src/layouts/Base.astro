---
interface Props {
  title?: string;
  minimal?: boolean;
}
const { title = 'AI Katas', minimal = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+JP:wght@700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="dot-grid"><canvas id="dotCanvas"></canvas></div>

    {!minimal && (
      <div class="oddball-banner">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
          <circle cx="100" cy="100" r="85" fill="none" stroke="#fff" stroke-width="14"/>
          <circle cx="100" cy="100" r="45" fill="none" stroke="#fff" stroke-width="14"/>
        </svg>
        oddball.io <span>— internal engineering resource</span>
      </div>
    )}

    <slot />

    {!minimal && <footer class="footer">AI Katas — Internal Use Only</footer>}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
